# SafeRoute environment variables config

# The URL of your backend API (e.g., Fast API, Express, Django) serving hotspots
# If set, SafeRoute will fetch hotspot data dynamically from: $HOTSPOTS_API_URL/api/hotspots
# If left commented or empty, SafeRoute will fall back to using your local 'data/kathmandu_hotspots.json'
HOTSPOTS_API_URL=http://localhost:8000
